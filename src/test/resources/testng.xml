<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Petstore API Automation Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="com.quality.api.utils.AnnotationTransformer"/>
    </listeners>

    <test name="Pet Management Endpoints">
        <classes>
            <class name="com.quality.api.tests.PetTests"/>
        </classes>
    </test>

    <test name="User Management Endpoints">
        <classes>
            <class name="com.quality.api.tests.UserTests"/>
            <class name="com.quality.api.tests.AuthTests"/>
        </classes>
    </test>

    <test name="Error Handling &amp; Negative Scenarios">
        <classes>
            <class name="com.quality.api.tests.NegativeTests"/>
        </classes>
    </test>

    <test name="End-to-End Integration Flows">
        <classes>
            <class name="com.quality.api.tests.IntegrationTests"/>
        </classes>
    </test>

</suite>
